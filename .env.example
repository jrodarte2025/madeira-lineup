# Per-deployment env template — copy to .env.local and fill in real values.
# .env.local is gitignored; .env.example is checked in (no secrets here).
#
# Every VITE_* key is substituted at Vite build time via import.meta.env.
# All values are consumed through src/config.js — DO NOT read import.meta.env
# anywhere else in the codebase.

# Short slug identifying this deployment. Used for telemetry + hosting naming.
# Examples: "madeira", "friendsteam"
VITE_DEPLOYMENT_ID=your-deployment-slug

# Firebase web app credentials
# Find these in: Firebase Console → Project Settings → Your Apps → Web app
VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abcdef0123456789
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Game structure model — choose one:
#   halves    — 2 x 25-min halves (Madeira default, 9v9)
#   quarters  — 4 x 12-min quarters (friend's team, 7v7; Phase 10 adds this)
VITE_GAME_STRUCTURE=halves

# Team name — required. Replaces every hardcoded "Madeira FC" string in the UI.
# Rendered as `${TEAM_NAME} FC` in the header, print view, and share surfaces.
# Examples: "Madeira", "Cincinnati United"
VITE_TEAM_NAME=Your Team Name
