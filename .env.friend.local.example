# Template for a second-deployment env file.
# Copy to .env.friend.local (gitignored) and fill in real values.
# Used by `npm run dev:friend` / `npm run build:friend` (Vite --mode friend).

VITE_DEPLOYMENT_ID=friend
VITE_TEAM_NAME=Friend FC
VITE_GAME_STRUCTURE=quarters

# Firebase credentials for the second Firebase project.
# Get these from: Firebase Console → Project Settings → Your Apps → Web app
# Phase 11 replaces the placeholders below with real values.
VITE_FIREBASE_API_KEY=your-friend-instance-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-friend-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-friend-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-friend-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abcdef0123456789
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
